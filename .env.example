# === LLM API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === Database ===
POSTGRES_URL=postgresql://postgres:postgres@db:5432/mapo_simulator
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === External API Keys (공공데이터포털 등) ===
SEOUL_OPENDATA_KEY=your_key_here
SEMAS_API_KEY=your_key_here
SGIS_API_KEY=your_key_here
SGIS_SECRET_KEY=your_secret_here
MOLIT_API_KEY=your_key_here
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# === LangSmith (에이전트 모니터링) ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=mapo-franchise-simulator

# === App ===
DEBUG=false
DEMO_MODE=false
